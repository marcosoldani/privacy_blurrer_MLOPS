# =============================================================================
# Privacy Blurrer — .gitignore
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg
*.egg-info/
.Python
build/
dist/
sdist/
wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ─────────────────────────────────────────────────────
.env
.envrc
.venv
venv/
env/
ENV/

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.cache
.hypothesis/

# ── Type checkers / linters cache ────────────────────────────────────────────
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.bak
*.tmp
# .vscode/    # decommenta se non vuoi tracciare i settings VS Code
# .idea/      # decommenta se nessuno usa PyCharm

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/*.jsonl

# ── Dataset (rigenerabile da preprocess.py) ──────────────────────────────────
data/

# ── Modelli derivati (rigenerabili da quantize_model.py / export_onnx.py) ────
experiments/best.onnx
experiments/best.onnx.data
experiments/best_int8.pt
experiments/best_fp16.pt

# ── Maschere generate dall'inferenza locale ──────────────────────────────────
*_mask.png

# ── MLflow ───────────────────────────────────────────────────────────────────
# Backend legacy file-based (non usato, sostituito da SQLite mlflow.db)
mlruns/
experiments/mlruns/
mlartifacts/
experiments/mlflow.db.legacy_backup

# Database generici (SQLite, ecc.)
*.db
# … MA mantieni mlflow.db nel repo per riproducibilità del run finale
!experiments/mlflow.db

# ── Frontend ─────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
*.tsbuildinfo

# ── Docker ───────────────────────────────────────────────────────────────────
*.tar